<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" prefWidth="450" prefHeight="350" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.controller.ActorsController"
      style="-fx-background-color: #f4f4f4;">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label fx:id="movieTitleLabel" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #333;"/>

    <TableView fx:id="actorsTable" VBox.vgrow="ALWAYS" style="-fx-border-color: #ddd;">
        <columns>
            <TableColumn fx:id="nameColumn" text="Ім'я актора" prefWidth="200"/>
            <TableColumn fx:id="roleColumn" text="Роль у фільмі" prefWidth="200"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
    </TableView>

</VBox>
